{
  "version": 4,
  "configurations": [
    {
      "name": "STM32F407-FreeRTOS",
      "includePath": [
        "${workspaceFolder}/Core/Inc",
        "${workspaceFolder}/Core/Src",
        "${workspaceFolder}/Core/Startup",
        "${workspaceFolder}/Drivers/STM32F4xx_HAL_Driver/Inc",
        "${workspaceFolder}/Drivers/STM32F4xx_HAL_Driver/Inc/Legacy",
        "${workspaceFolder}/Drivers/CMSIS/Device/ST/STM32F4xx/Include",
        "${workspaceFolder}/Drivers/CMSIS/Include",
        "${workspaceFolder}/ThirdParty/FreeRTOS",
        "${workspaceFolder}/ThirdParty/FreeRTOS/include",
        "${workspaceFolder}/ThirdParty/FreeRTOS/portable/GCC/ARM_CM4F"
      ],
      "defines": [
        "USE_HAL_DRIVER",
        "STM32F407xx",
        "DEBUG"
      ],
      "compilerPath": "arm-none-eabi-gcc",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "intelliSenseMode": "windows-gcc-arm",
      "browse": {
        "path": [
          "${workspaceFolder}/Core",
          "${workspaceFolder}/Drivers",
          "${workspaceFolder}/ThirdParty"
        ],
        "limitSymbolsToIncludedHeaders": true,
        "databaseFilename": "${workspaceFolder}/.vscode/browse.vc.db"
      }
    }
  ]
}
